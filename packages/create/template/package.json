{
  "name": "@duxweb/uni-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean:vite": "node -e \"import('node:fs').then(fs => fs.rmSync('node_modules/.vite', { recursive: true, force: true }))\"",
    "sync:uni": "node ../../packages/uni/bin/dux-uni.mjs sync",
    "dev": "pnpm clean:vite && pnpm --filter @duxweb/uni build && node ../../packages/uni/bin/dux-uni.mjs dev",
    "build": "pnpm --filter @duxweb/uni build && node ../../packages/uni/bin/dux-uni.mjs build",
    "about": "pnpm --filter @duxweb/uni build && node ../../packages/uni/bin/dux-uni.mjs about",
    "module:new": "node ../../packages/uni/bin/dux-uni.mjs module new",
    "type-check": "pnpm sync:uni && vue-tsc --noEmit",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000520260324001",
    "@dcloudio/uni-app-harmony": "3.0.0-5000520260324001",
    "@dcloudio/uni-app-plus": "3.0.0-5000520260324001",
    "@dcloudio/uni-components": "3.0.0-5000520260324001",
    "@dcloudio/uni-h5": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-alipay": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-baidu": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-harmony": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-jd": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-lark": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-qq": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000520260324001",
    "@dcloudio/uni-mp-xhs": "3.0.0-5000520260324001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-5000520260324001",
    "@duxweb/uni": "workspace:*",
    "@duxweb/uni-pro": "workspace:*",
    "@uni-helper/uni-network": "^0.23.1",
    "@uni-helper/uni-promises": "^0.2.1",
    "@uni-helper/uni-use": "^0.19.17",
    "@vueuse/core": "12.8.2",
    "@vueuse/shared": "12.8.2",
    "fast-decode-uri-component": "^1.0.1",
    "fast-querystring": "^1.1.2",
    "lodash.merge": "^4.6.2",
    "pinia": "2.1.7",
    "pinia-plugin-persist-uni": "^1.3.2",
    "statuses-es": "^2.0.6",
    "vue": "3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-router": "4.5.1",
    "wot-design-uni": "^1.14.0"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.28",
    "@dcloudio/uni-automator": "3.0.0-5000520260324001",
    "@dcloudio/uni-cli-shared": "3.0.0-5000520260324001",
    "@dcloudio/uni-stacktracey": "3.0.0-5000520260324001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000520260324001",
    "@iconify-json/carbon": "^1.2.11",
    "@mini-types/alipay": "^3.0.14",
    "@types/node": "^24.1.0",
    "@uni-helper/eslint-config": "^0.4.0",
    "@uni-helper/uni-types": "1.0.0-alpha.6",
    "@uni-helper/unocss-preset-uni": "^0.2.11",
    "@unocss/eslint-config": "^66.3.3",
    "@vue/runtime-core": "3.4.21",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.32.0",
    "lint-staged": "^16.1.2",
    "miniprogram-api-typings": "^4.1.0",
    "sass": "1.78.0",
    "simple-git-hooks": "^2.13.0",
    "typescript": "~5.8.3",
    "unocss": "66.0.0",
    "unplugin-auto-import": "^19.3.0",
    "vite": "5.2.8",
    "vite-plugin-uni-polyfill": "^0.1.0",
    "vitest": "^3.2.4",
    "vitest-environment-uniapp": "^0.0.5",
    "vue-tsc": "^3.0.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
