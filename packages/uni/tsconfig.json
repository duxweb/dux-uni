{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": [
      "ES2020",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "src",
    "test",
    "tsup.config.ts"
  ]
}
