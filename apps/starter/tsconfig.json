{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@duxweb/uni": ["../../packages/uni/src/index.ts"],
      "@duxweb/uni-pro": ["../../packages/uni-pro/src/index.ts"],
      "@duxweb/uni-pro/*": ["../../packages/uni-pro/src/*"]
    },
    "types": [
      "@dcloudio/types",
      "@mini-types/alipay",
      "miniprogram-api-typings",
      "pinia-plugin-persist-uni",
      "@uni-helper/uni-types",
      "vitest-environment-uniapp/types"
    ],
    "sourceMap": true,
    "skipLibCheck": true
  },
  "vueCompilerOptions": {
    // 调整 Volar（Vue 语言服务工具）解析行为，用于为 uni-app 组件提供 TypeScript 类型
    "plugins": ["@uni-helper/uni-types/volar-plugin"]
  }
}
